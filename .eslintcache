     <li className=\"readers-form__item\">\r\n               <InputGroup\r\n                  label=\"Name\"\r\n                  isCol\r\n                  placeholder=\"Staffs's Full Name\"\r\n                  disabled\r\n                  value={name}\r\n                  name=\"name\"\r\n               ></InputGroup>\r\n            </li>\r\n            <li className=\"readers-form__item\">\r\n               <InputGroup\r\n                  label=\"User Name\"\r\n                  isCol\r\n                  placeholder=\"Staffs's User Name\"\r\n                  disabled\r\n                  value={initValues.username}\r\n                  name=\"username\"\r\n               ></InputGroup>\r\n            </li>\r\n            <li className=\"readers-form__item\">\r\n               <InputGroup\r\n                  label=\"Email\"\r\n                  isCol\r\n                  placeholder=\"Staffs's Email\"\r\n                  disabled\r\n                  value={email}\r\n                  name=\"email\"\r\n               ></InputGroup>\r\n            </li>\r\n            <li className=\"readers-form__item\">\r\n               <InputGroup\r\n                  label=\"Phone\"\r\n                  isCol\r\n                  placeholder=\"Staffs's Phone Number\"\r\n                  disabled\r\n                  value={phone}\r\n                  type=\"number\"\r\n                  name=\"phone\"\r\n               ></InputGroup>\r\n            </li>\r\n         </ul>\r\n         <div className=\"readers-form__actions\">\r\n            <Button type=\"button\" className=\"btn--danger\">\r\n               <i className=\"fa fa-trash\" aria-hidden=\"true\"></i>Delete\r\n            </Button>\r\n            <Button\r\n               type=\"button\"\r\n               className=\"btn btn--info\"\r\n               onClick={handleBackClick}\r\n            >\r\n               <i className=\"fa fa-long-arrow-left\" aria-hidden=\"true\"></i>\r\n               Back\r\n         