\git\\reactjs-library_management\\src\\component\\Login\\Login.jsx",["88","89","90"],"import React, { useState } from \"react\";\r\nimport { Link } from \"react-router-dom\";\r\nimport { useForm } from \"react-hook-form\";\r\nimport Button from \"../Button/Button\";\r\nimport \"./Login.scss\";\r\nimport InputGroup from \"../InputGroup/InputGroup\";\r\nimport useInput from \"../../hooks/useInput\";\r\n\r\nfunction Login(props) {\r\n   const [username, handleUsernameChange, resetUsername] = useInput(\"\");\r\n   const [password, handlePasswordChange, resetPassword] = useInput(\"\");\r\n   const { register, handleSubmit, errors } = useForm({\r\n      reValidateMode: \"onSubmit\",\r\n   });\r\n   const onSubmit = (data) => {\r\n      console.log(data);\r\n   };\r\n   return (\r\n      <div className=\"login\">\r\n         <div className=\"login__header\">\r\n            <p className=\"login__title\">Login</p>\r\n         </div>\r\n         <form\r\n            action=\"\"\r\n            className=\"login__form\"\r\n            onSubmit={handleSubmit(onSubmit)}\r\n         >\r\n            <InputGroup\r\n               name=\"username\"\r\n               placeholder=\"Username\"\r\n               icon=\"fa fa-user\"\r\n               value={username}\r\n               onChange={handleUsernameChange}\r\n               innerRef={register({\r\n                  required: \"Username is required.\",\r\n               })}\r\n               errors={errors.username ? errors.username.message : \"\"}\r\n            ></InputGroup>\r\n            <InputGroup\r\n               name=\"password\"\r\n               placeholder=\"Password\"\r\n               type=\"password\"\r\n               icon=\"fa fa-lock\"\r\n               value={password}\r\n               onChange={handlePasswordChange}\r\n               innerRef={register({\r\n                  required: \"Password is required.\",\r\n               })}\r\n               errors={errors.password ? errors.password.message : \"\"}\r\n            ></InputGroup>\r\n            <div className=\"login__submit\">\r\n               <Button type=\"submit\" className=\"btn--primary\">\r\n                  Sign in\r\n               </Button>\r\n               <Link to=\"/forgetpassword\" className=\"login__link\">\r\n                  Forgot Password?\r\n               </Link>\r\n            </div>\r\n            <div className=\"login__bottom\">\r\n               <Link to=\"/register\" className=\"login__link\">\r\n                  Sign up now\r\n               </Link>\r\n            </div>\r\n         </form>\r\n      </div>\r\n   );\r\n}\r\n\r\nexport default Login;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Button\\Button.jsx",["91"],"import React from \"react\";\r\nimport \"./Button.scss\";\r\nimport PropTypes from \"prop-types\";\r\n\r\nButton.propTypes = {\r\n   className: PropTypes.string,\r\n   onClick: PropTypes.func,\r\n};\r\n\r\nfunction Button(props) {\r\n   const { className, onClick, children, ...buttonProps } = props;\r\n   return (\r\n      <button\r\n         {...buttonProps}\r\n         className={\"btn\" + \" \" + className}\r\n         onClick={onClick}\r\n      >\r\n         {children}\r\n      </button>\r\n   );\r\n}\r\n\r\nexport default Button;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\InputGroup\\InputGroup.jsx",[],"C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\hooks\\useInput.js",["92"],"import { useEffect, useState } from \"react\";\r\n\r\nfunction useInput(initValue = \"\") {\r\n   const [value, setValue] = useState(initValue);\r\n\r\n   const resetValue = () => {\r\n      setValue(initValue);\r\n   };\r\n\r\n   const handleChange = (e) => {\r\n      setValue(e.target.value);\r\n   };\r\n\r\n   return [value, handleChange, resetValue];\r\n}\r\n\r\nexport default useInput;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\layout\\MainLayout\\MainLayout.jsx",[],"C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Header\\Header.jsx",["93","94"],"import React from \"react\";\r\nimport PropTypes from \"prop-types\";\r\nimport \"./Header.scss\";\r\nimport Logo from \"../Logo/Logo\";\r\n\r\nHeader.propTypes = {};\r\n\r\nfunction Header(props) {\r\n   function handleToggleClick() {\r\n      props.handleClick();\r\n   }\r\n   return (\r\n      <header className=\"header\">\r\n         <div className=\"header__left\">\r\n            <button className=\"toggle\" onClick={handleToggleClick}>\r\n               <i className=\"fa fa-bars\" aria-hidden=\"true\"></i>\r\n            </button>\r\n            <Logo></Logo>\r\n         </div>\r\n         <div className=\"header__right\">\r\n            <a href=\"\" className=\"header__logout\">\r\n               <i className=\"fa fa-sign-out\" aria-hidden=\"true\"></i> Logout\r\n            </a>\r\n         </div>\r\n      </header>\r\n   );\r\n}\r\n\r\nexport default Header;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\SideBar\\SideBar.jsx",["95","96"],"import React from \"react\";\r\nimport Logo from \"../Logo/Logo\";\r\nimport Navbar from \"../Navbar/Navbar\";\r\nimport \"./SideBar.scss\";\r\nimport UserAccount from \"./UserAccount/UserAccount\";\r\n\r\nfunction SideBar(props) {\r\n   return (\r\n      <div className={\"sidebar\" + \" \" + props.className}>\r\n         <UserAccount></UserAccount>\r\n         <Navbar></Navbar>\r\n      </div>\r\n   );\r\n}\r\n\r\nexport default SideBar;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Content\\Content.jsx",["97"],"import React from \"react\";\r\nimport BreadCrumb from \"../BreadCrumb/BreadCrumb\";\r\nimport \"./Content.scss\";\r\n\r\nfunction Content(props) {\r\n   return (\r\n      <div className={\"content\" + \" \" + props.className}>\r\n         <BreadCrumb></BreadCrumb>\r\n         {props.children}\r\n      </div>\r\n   );\r\n}\r\n\r\nexport default Content;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Logo\\Logo.jsx",["98"],"import React from \"react\";\r\nimport \"./Logo.scss\";\r\n\r\nfunction Logo(props) {\r\n   return (\r\n      <a href=\"\" className=\"logo\">\r\n         <h3>\r\n            Library <span>Management</span>\r\n         </h3>\r\n      </a>\r\n   );\r\n}\r\n\r\nexport default Logo;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\SideBar\\UserAccount\\UserAccount.jsx",["99"],"import React from \"react\";\r\nimport PropTypes from \"prop-types\";\r\nimport \"./UserAccount.scss\";\r\n\r\nUserAccount.propTypes = {};\r\n\r\nfunction UserAccount(props) {\r\n   return (\r\n      <div className=\"useraccount\">\r\n         <div className=\"useraccount__imgbox\">\r\n            <img\r\n               src=\"https://images.pexels.com/photos/1036623/pexels-photo-1036623.jpeg?auto=compress&cs=tinysrgb&dpr=2&w=500\"\r\n               alt=\"\"\r\n               className=\"useraccount__img\"\r\n            />\r\n         </div>\r\n         <div className=\"useraccount__info\">\r\n            <p className=\"useraccount__name\">Minh Sang</p>\r\n            <p className=\"useraccount__role\">Admin</p>\r\n         </div>\r\n      </div>\r\n   );\r\n}\r\n\r\nexport default UserAccount;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\BreadCrumb\\BreadCrumb.jsx",[],"C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Navbar\\Navbar.jsx",[],"C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\DropDown\\DropDown.jsx",["100","101"],"import React, { useRef, useState } from \"react\";\r\nimport \"./DropDown.scss\";\r\nimport classNames from \"classnames\";\r\nimport { Link, NavLink, Route } from \"react-router-dom\";\r\n\r\nfunction DropDown(props) {\r\n   const { listItem } = props;\r\n   const [isOpen, setIsOpen] = useState(false);\r\n   const dropdownListRef = useRef();\r\n   function handleClick() {\r\n      if (isOpen) {\r\n         setIsOpen(false);\r\n         dropdownListRef.current.style.maxHeight = \"0px\";\r\n      } else {\r\n         setIsOpen(true);\r\n         dropdownListRef.current.style.maxHeight =\r\n            dropdownListRef.current.scrollHeight + \"px\";\r\n      }\r\n   }\r\n   return (\r\n      <Route\r\n         path={listItem.map((item) => \"/\" + item.link)}\r\n         children={({ match }) => {\r\n            let active = match ? \" active\" : \"\";\r\n            return (\r\n               <div\r\n                  className={classNames(\"dropdown\", { open: isOpen }) + active}\r\n               >\r\n                  {listItem.map((item, index) => {\r\n                     <p key={index}>{item.name}</p>;\r\n                  })}\r\n                  <button className=\"dropdown__title\" onClick={handleClick}>\r\n                     <span className=\"dropdown__name\">\r\n                        <i className={props.icon} aria-hidden=\"true\"></i>\r\n                        {props.name}\r\n                     </span>\r\n                  </button>\r\n                  <ul ref={dropdownListRef} className=\"dropdown__list\">\r\n                     {listItem.map((item, index) => {\r\n                        return (\r\n                           <li key={index} className=\"dropdown__item\">\r\n                              <NavLink\r\n                                 activeClassName=\"active\"\r\n                                 to={\"/\" + item.link}\r\n                                 className=\"dropdown__item-link\"\r\n                              >\r\n                                 {item.name}\r\n                              </NavLink>\r\n                           </li>\r\n                        );\r\n                     })}\r\n                  </ul>\r\n               </div>\r\n            );\r\n         }}\r\n      />\r\n   );\r\n}\r\n\r\nexport default DropDown;\r\n",["102","103"],"C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Routes\\PrivateRoute\\PrivateRoute.jsx",["104"],"import React, { useState } from \"react\";\r\nimport { Redirect, Route } from \"react-router-dom\";\r\n\r\nfunction PrivateRoute({ component: Component, layout: Layout, ...rest }) {\r\n   const [isLogin, setIsLogin] = useState(true);\r\n   return (\r\n      <Route\r\n         {...rest}\r\n         render={(props) =>\r\n            isLogin ? (\r\n               <Layout {...props}>\r\n                  <Component {...props} />\r\n               </Layout>\r\n            ) : (\r\n               <Redirect to=\"/login\" />\r\n            )\r\n         }\r\n      />\r\n   );\r\n}\r\n\r\nexport default PrivateRoute;\r\n","C:\\Users\\Sang\\Desktop\\git\\reactjs-library_management\\src\\component\\Home\\Home.jsx",[],{"ruleId":"105","replacedBy":"106"},{"ruleId":"107","replacedBy":"108"},{"ruleId":"109","severity":1,"message":"110","line":1,"column":17,"nodeType":"111","messageId":"112","endLine":1,"endColumn":25},{"ruleId":"109","severity":1,"message":"113","line":10,"column":43,"nodeType":"111","messageId":"112","endLine":10,"endColumn":56},{"ruleId":"109","severity":1,"message":"114","line":11,"column":43,"nodeType":"111","messageId":"112","endLine":11,"endColumn":56},{"ruleId":"115","severity":1,"message":"116","line":15,"column":27,"nodeType":"117","messageId":"118","endLine":15,"endColumn":28},{"ruleId":"109","severity":1,"message":"119","line":1,"column":10,"nodeType":"111","messageId":"112","endLine":1,"endColumn":19},{"ruleId":"109","severity":1,"message":"120","line":2,"column":8,"nodeType":"111","messageId":"112","endLine":2,"endColumn":17},{"ruleId":"121","severity":1,"message":"122","line":21,"column":13,"nodeType":"123","endLine":21,"endColumn":51},{"ruleId":"109","severity":1,"message":"124","line":2,"column":8,"nodeType":"111","messageId":"112","endLine":2,"endColumn":12},{"ruleId":"115","severity":1,"message":"116","line":9,"column":33,"no